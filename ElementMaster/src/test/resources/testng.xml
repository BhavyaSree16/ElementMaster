<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Suite" parallel="false" thread-count="5">
  <listeners>
        <listener class-name="utils.TestListener"/>
    </listeners>
    
<!-- Test Module-1  -->
    <test name="FormTests">
        <classes>
            <class name="tests.FormTest"/>
        </classes>
    </test>
    
<!-- Test Module-2  -->    
    <test name="WebTableTests">
        <classes>
            <class name="tests.WebTableTest"/>
        </classes>
    </test>
    
<!-- Module 3 Tests -->
    <test name="Module3Tests">
        <classes>
            <class name="tests.AlertsTest"/>
            <class name="tests.FramesTest"/>
            <class name="tests.WindowsTest"/>
        </classes>
    </test> <!-- Test -->
</suite> <!-- Suite -->
